{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'config:recommended',
  ],
  platformAutomerge: true,
  packageRules: [
    {
      matchUpdateTypes: [
        'minor',
        'patch',
        'digest',
      ],
      automerge: true,
    },
    {
      groupName: 'caddy-crowdsec-bouncer',
      matchPackageNames: [
        '/github\\.com/hslatman/caddy-crowdsec-bouncer/',
      ],
    },
    {
      matchDatasources: [
        'docker',
      ],
      matchPackageNames: [
        'golang',
      ],
      prCreation: 'immediate',
      minimumReleaseAge: null,
    },
  ],
  customManagers: [
    {
      customType: 'regex',
      managerFilePatterns: [
        '/Dockerfile/',
      ],
      matchStrings: [
        'CADDY_VERSION=(?<currentValue>v\\d+\\.\\d+\\.\\d+)',
      ],
      datasourceTemplate: 'go',
      packageNameTemplate: 'github.com/caddyserver/caddy/v2',
      versioningTemplate: 'semver',
    },
    {
      customType: 'regex',
      managerFilePatterns: [
        '/Dockerfile/',
      ],
      matchStrings: [
        '(?<packageName>github\\.com/[^\\s@]+)@(?<currentValue>v?\\d+\\.\\d+\\.\\d+(\\-[0-9]+\\-[a-z0-9]+)?)',
      ],
      datasourceTemplate: 'go',
      packageNameTemplate: '{{packageName}}',
      versioningTemplate: 'semver',
    },
  ],
}
